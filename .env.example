# Primary provider. Supported values: finnhub, polygon, twelvedata
MARKET_DATA_PROVIDER=finnhub

# Automatic fallback order when the primary provider is unavailable.
MARKET_DATA_FALLBACKS=polygon,twelvedata

# Keep real keys in .env.local and in the hosting platform's secret settings.
FINNHUB_API_KEY=
POLYGON_API_KEY=
TWELVE_DATA_API_KEY=

# Never enable mock data in production. It is intended only for local previews.
ALLOW_MOCK_MARKET_DATA=false
