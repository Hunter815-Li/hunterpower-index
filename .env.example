# Public site configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=libangtao0815@gmail.com
NEXT_PUBLIC_RESUME_URL=
# Prefer a local public path such as /wechat-qr.png
NEXT_PUBLIC_WECHAT_QR=/wechat-qr.jpg

# HPI equities and benchmarks. Use fmp on serverless hosts such as Vercel.
MARKET_DATA_PROVIDER=fmp
MARKET_DATA_FALLBACKS=marketdata,twelvedata,polygon,finnhub
MARKETDATA_TOKEN=
POLYGON_API_KEY=
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=

# Free FRED key: market board plus U.S. macro series and BLS/BEA mirror fallbacks.
FRED_API_KEY=
# Optional primary-source access. The dashboard falls back to FRED mirrors when these are absent or unavailable.
BLS_API_KEY=
BEA_API_KEY=

# Economic calendar (China and United States). Stored server-side only.
FMP_API_KEY=

# Optional. BTC can use CoinGecko's keyless public API; a Demo key improves reliability.
COINGECKO_DEMO_API_KEY=

# Local preview only. Production ignores simulated data even when set.
ALLOW_MOCK_MARKET_DATA=false

# Optional durable infrastructure
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/taotalk_finance
REDIS_URL=

# Protected Vercel cron endpoint
CRON_SECRET=
MACRO_ADMIN_TOKEN=
