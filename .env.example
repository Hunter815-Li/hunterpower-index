# Daily EOD provider. Supported values: marketdata, polygon, twelvedata, finnhub
MARKET_DATA_PROVIDER=marketdata

# Optional fallback order; only providers with a configured key are used.
MARKET_DATA_FALLBACKS=twelvedata,polygon

# Keep real keys in .env.local and in the hosting platform's secret settings.
MARKETDATA_TOKEN=
TWELVE_DATA_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=

# Vercel sends this token to the private daily cron route.
CRON_SECRET=

# Never enable mock data in production. It is intended only for local previews.
ALLOW_MOCK_MARKET_DATA=false
